// ==================== Navigation ====================
function nextStep() {
  if (STATE.step === 0 && !STATE.uploadedFile) return;
  if (STATE.step === 1 && !STATE.selectedFocus) return;
  if (STATE.step < 5) {
    STATE.step++;
    if (STATE.step === 2) {
      STATE.blueprint = JSON.parse(JSON.stringify(INITIAL_BLUEPRINT));
      showToast('🌳 AI 已生成叙事蓝图，你可以拖拽调整结构');
    }
    if (STATE.step === 3) {
      initWorkshop();
      showToast('🚀 已启动 5 个并行智能体，开始生成各章节');
    }
    if (STATE.step === 4) {
      STATE.reviewItems = REVIEW_ITEMS.map(r => ({...r, resolved: false}));
      showToast('🔍 AI 审查智能体已启动，发现 ' + STATE.reviewItems.length + ' 条建议');
    }
    renderPanel();
  }
}

function prevStep() {
  if (STATE.step > 0) {
    STATE.step--;
    renderPanel();
  }
}

function goToStep(n) {
  STATE.step = n;
  if (n === 2 && !STATE.blueprint) STATE.blueprint = JSON.parse(JSON.stringify(INITIAL_BLUEPRINT));
  if (n === 3 && STATE.tasks.length === 0) initWorkshop();
  if (n === 4 && STATE.reviewItems.length === 0) STATE.reviewItems = REVIEW_ITEMS.map(r => ({...r, resolved: false}));
  renderPanel();
}

function updateSteps() {
  const steps = document.querySelectorAll('#stepsBar .step');
  steps.forEach((el, i) => {
    el.classList.remove('active', 'done');
    if (i < STATE.step) el.classList.add('done');
    if (i === STATE.step) el.classList.add('active');
    el.onclick = () => goToStep(i);
  });
}

function updateActionBar() {
  const btn = document.getElementById('btnNext');
  const hint = document.getElementById('actionHint');
  const resetBtn = document.getElementById('btnReset');

  if (resetBtn) resetBtn.style.display = STATE.step > 0 ? '' : 'none';

  if (STATE.step === 0) {
    btn.disabled = !STATE.uploadedFile;
    hint.textContent = STATE.uploadedFile ? '论文已上传，点击下一步' : '拖拽 PDF 文件到上方区域，或点击上传';
  } else if (STATE.step === 1) {
    btn.disabled = !STATE.selectedFocus;
    hint.textContent = STATE.selectedFocus ? '已选择侧重点，点击下一步生成蓝图' : '请选择一种解读模式';
  } else if (STATE.step === 2) {
    btn.disabled = false;
    hint.textContent = '调整蓝图后点击下一步，启动并行生成';
  } else if (STATE.step === 3) {
    const allDone = STATE.tasks.length > 0 && STATE.tasks.every(t => t.status === 'done');
    btn.disabled = !allDone;
    hint.textContent = allDone ? '全部章节生成完毕，进入审查' : '等待所有智能体完成，或手动暂停/修改指令...';
  } else if (STATE.step === 4) {
    btn.disabled = false;
    hint.textContent = '处理审查建议后，点击下一步导出';
  } else if (STATE.step === 5) {
    btn.style.display = 'none';
    hint.textContent = '选择导出格式完成演示';
  }
}

// ==================== Init Workshop ====================
function initWorkshop() {
  const focusModeName = FOCUS_MODES.find(f => f.id === STATE.selectedFocus)?.title || '综述概览';
  STATE.tasks = TASK_DEFS.map(t => ({
    ...t,
    status: 'running',
    progress: 0,
    preview: '',
    instruction: `在「${focusModeName}」模式下生成「${t.title}」章节的幻灯片内容。`,
    icon: t.icon,
  }));
  // Trigger simulations
  setTimeout(() => {
    STATE.tasks.forEach(t => {
      if (t.status === 'running') simulateProgress(t.id);
    });
  }, 500);
}

// ==================== Panel Events ====================
function bindPanelEvents() {
  // Upload step
  const zone = document.getElementById('uploadZone');
  if (zone) {
    zone.addEventListener('click', () => simulateUpload());
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag'));
    zone.addEventListener('drop', e => {
      e.preventDefault();
      zone.classList.remove('drag');
      simulateUpload();
    });
  }

  // Focus cards
  document.querySelectorAll('.focus-card').forEach(card => {
    card.addEventListener('click', () => {
      STATE.selectedFocus = card.dataset.focus;
      renderPanel();
    });
  });

  // Tree node drag & drop (step 2)
  if (STATE.step === 2) initDragDrop();

  // Workshop task card clicks (step 3)
  document.querySelectorAll('.task-card').forEach(card => {
    card.addEventListener('click', function(e) {
      if (e.target.tagName === 'BUTTON') return;
      const id = this.id.replace('card-', '');
      const task = STATE.tasks.find(t => t.id === id);
      if (task) {
        const stack = document.getElementById('workshopSlidesStack');
        if (stack) {
          stack.innerHTML = renderSlideStack(id) || '<div class="stacked-slide"><div class="slide-inner"><span class="placeholder">该章节内容生成中...</span></div></div>';
        }
      }
    });
  });

  // Blueprint tree node clicks (step 2)
  document.querySelectorAll('.tree-node .row').forEach(row => {
    row.addEventListener('click', function(e) {
      if (e.target.tagName === 'BUTTON' || e.target.tagName === 'INPUT' || e.target.classList.contains('toggle')) return;
      const id = this.dataset.nodeId;
      if (id) {
        const stack = document.getElementById('previewSlidesStack');
        if (stack) {
          stack.innerHTML = renderSlideStack(id);
        }
      }
    });
  });
}

function simulateUpload() {
  STATE.uploadedFile = {
    name: 'Attention_Is_All_You_Need.pdf',
    pages: 10,
    size: '2.4 MB',
  };
  renderPanel();
  showToast('📄 论文已解析，共 10 页，识别出 5 个主要章节');
}

function initDragDrop() {
  let dragged = null;

  document.querySelectorAll('.tree-node .row').forEach(row => {
    row.addEventListener('dragstart', function(e) {
      dragged = this;
      this.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', this.dataset.nodeId);
    });

    row.addEventListener('dragend', function() {
      this.classList.remove('dragging');
      document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
      dragged = null;
    });

    row.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      if (this !== dragged) this.classList.add('drag-over');
    });

    row.addEventListener('dragleave', function() {
      this.classList.remove('drag-over');
    });

    row.addEventListener('drop', function(e) {
      e.preventDefault();
      e.stopPropagation();
      this.classList.remove('drag-over');
      if (dragged && this !== dragged) {
        const srcId = dragged.dataset.nodeId;
        const dstId = this.dataset.nodeId;
        moveNode(srcId, dstId);
      }
    });
  });
}

function moveNode(srcId, dstId) {
  const bp = STATE.blueprint;
  let srcNode = null, srcParent = null, srcIdx = -1;
  let dstParent = null, dstIdx = -1;

  function find(nodes, parent = null) {
    for (let i = 0; i < nodes.length; i++) {
      if (nodes[i].id === srcId) { srcNode = nodes[i]; srcParent = nodes; srcIdx = i; }
      if (nodes[i].id === dstId) { dstParent = nodes; dstIdx = i; }
      if (nodes[i].children) find(nodes[i].children, nodes[i]);
    }
  }
  find(bp);

  if (srcNode && dstParent && srcIdx >= 0 && dstIdx >= 0) {
    srcParent.splice(srcIdx, 1);
    // Adjust dstIdx if src was before dst in same parent
    const insertIdx = (srcParent === dstParent && srcIdx < dstIdx) ? dstIdx : dstIdx + 1;
    dstParent.splice(insertIdx, 0, srcNode);
    renderPanel();
    showToast('📋 节点顺序已更新 · 内容区将自动重排');
  }
}

// ==================== Helpers ====================
function escapeHtml(str) {
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.classList.add('show');
  clearTimeout(toast._timeout);
  toast._timeout = setTimeout(() => toast.classList.remove('show'), 2500);
}

function resetAll() {
  if (!confirm('确定重新开始？当前所有进度将被清除。')) return;
  STATE.step = 0;
  STATE.uploadedFile = null;
  STATE.selectedFocus = null;
  STATE.blueprint = null;
  STATE.tasks = [];
  STATE.reviewItems = [];
  document.getElementById('btnNext').style.display = '';
  renderPanel();
  showToast('↺ 已重置');
}

// Keyboard shortcuts
document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
  if (e.key === 'ArrowRight' && !e.ctrlKey && !e.metaKey) nextStep();
  if (e.key === 'ArrowLeft' && !e.ctrlKey && !e.metaKey) prevStep();
});

// ==================== Init ====================
renderPanel();
</script>
