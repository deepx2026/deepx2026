
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StructuSlide — AI Native PPT 编辑器</title>
<style>
/* ===== Reset & Base ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #ffffff;
  --surface: #f5f6f8;
  --surface2: #eeeff2;
  --border: #e2e5ea;
  --text: #1e1f24;
  --text2: #6e727a;
  --accent: #2563eb;
  --accent2: #1d4ed8;
  --accent-light: #eff6ff;
  --accent-bar: #3b82f6;
  --green: #10b981;
  --green-light: #ecfdf5;
  --amber: #f59e0b;
  --amber-light: #fffbeb;
  --red: #ef4444;
  --red-light: #fef2f2;
  --blue: #93c5fd;
  --blue-light: #eff6ff;
  --shadow: 0 1px 3px rgba(0,0,0,.06);
  --shadow-lg: 0 4px 12px rgba(0,0,0,.08);
  --shadow-slide: 0 2px 16px rgba(0,0,0,.10);
  --radius: 10px;
  --radius-sm: 6px;
  --font: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}
html, body { height: 100%; }
body {
  font-family: var(--font);
  font-size: 15px;
  background: var(--bg);
  color: var(--text);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== Top Bar ===== */
.topbar {
  display: flex; align-items: center; gap: 16px;
  padding: 14px 24px; background: var(--surface);
  border-bottom: 2px solid var(--accent-light);
  z-index: 10;
}
.topbar .logo {
  font-size: 20px; font-weight: 700;
  color: var(--accent);
}
.topbar .sep { flex: 1; }
.topbar .badge {
  font-size: 12px; padding: 5px 12px; border-radius: 20px;
  background: var(--accent-light); color: var(--accent); font-weight: 600;
}

/* ===== Steps Bar ===== */
.steps {
  display: flex; gap: 0; padding: 18px 24px 0;
  background: var(--surface); border-bottom: 1px solid var(--border);
  overflow-x: auto;
}
.step {
  flex-shrink: 0; padding: 12px 22px; font-size: 14px; font-weight: 500;
  color: var(--text2); cursor: pointer; border-bottom: 3px solid transparent;
  transition: all .2s; white-space: nowrap;
  display: flex; align-items: center; gap: 8px;
}
.step .num {
  width: 24px; height: 24px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700;
  background: #eee; color: var(--text2);
  transition: all .2s;
}
.step.active { color: var(--accent); border-bottom-color: var(--accent); }
.step.active .num { background: var(--accent); color: #fff; }
.step.done { color: var(--green); }
.step.done .num { background: var(--green); color: #fff; }
.step:hover:not(.active) { color: var(--text); border-bottom-color: var(--accent-light); }

/* ===== Main Area ===== */
.main {
  flex: 1; display: flex; overflow: hidden; position: relative;
}

/* ===== Panels ===== */
.panel {
  display: none; flex-direction: column;
  position: absolute; inset: 0;
  padding: 32px; overflow-y: auto;
}
.panel.active { display: flex; }

/* Upload panel */
.upload-zone {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 18px;
  border: 2px dashed var(--accent-light); border-radius: var(--radius);
  margin: 20px; cursor: pointer; transition: all .2s;
  background: var(--surface2);
}
.upload-zone:hover { border-color: var(--accent); background: var(--blue-light); }
.upload-zone.drag { border-color: var(--accent); background: var(--accent-light); }
.upload-icon { font-size: 52px; }
.upload-text { font-size: 18px; font-weight: 600; }
.upload-hint { font-size: 14px; color: var(--text2); }
.uploaded-file {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 22px; background: var(--green-light); border-radius: var(--radius-sm);
  border: 1px solid #a7f3d0;
}
.uploaded-file .icon { font-size: 30px; }
.uploaded-file .name { font-weight: 600; font-size: 15px; }
.uploaded-file .meta { font-size: 13px; color: var(--text2); }
.uploaded-file .check { margin-left: auto; color: var(--green); font-size: 22px; }

/* Focus selection */
.focus-grid {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;
  flex: 1; align-content: center; max-width: 680px; margin: 0 auto;
}
.focus-card {
  padding: 26px; border: 2px solid var(--border); border-radius: var(--radius);
  cursor: pointer; transition: all .2s;
  background: var(--surface);
}
.focus-card:hover { border-color: var(--accent); }
.focus-card.selected { border-color: var(--accent); background: var(--blue-light); }
.focus-card .icon { font-size: 36px; margin-bottom: 10px; }
.focus-card .title { font-weight: 700; font-size: 17px; margin-bottom: 6px; }
.focus-card .desc { font-size: 13px; color: var(--text2); line-height: 1.6; }
.focus-card .checkmark {
  display: none; float: right;
  width: 24px; height: 24px; border-radius: 50%; background: var(--accent);
  color: #fff; text-align: center; line-height: 24px; font-size: 13px;
}
.focus-card.selected .checkmark { display: inline-block; }

/* Blueprint panel */
.blueprint-layout {
  display: flex; gap: 20px; flex: 1; overflow: hidden;
}
.tree-panel {
  flex: 1; max-width: 420px; background: var(--surface);
  border: 1px solid var(--border); border-radius: var(--radius);
  padding: 22px; overflow-y: auto;
}
.tree-panel h3 { font-size: 15px; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
.tree-node {
  margin-left: 0; user-select: none;
}
.tree-node .row {
  display: flex; align-items: center; gap: 8px;
  padding: 9px 10px; border-radius: 6px;
  cursor: grab; transition: background .15s; font-size: 14px;
}
.tree-node .row:hover { background: var(--accent-light); }
.tree-node .row.dragging { opacity: .4; }
.tree-node .row.drag-over { background: var(--blue-light); outline: 2px dashed var(--accent); border-radius: 6px; }
.tree-node .row .toggle { width: 18px; cursor: pointer; color: var(--text2); font-size: 11px; }
.tree-node .row .label { flex: 1; }
.tree-node .row .label input {
  border: none; background: transparent; font-size: 14px; font-family: var(--font);
  width: 100%; padding: 2px 4px; border-radius: 4px;
}
.tree-node .row .label input:focus { outline: none; background: #fff; box-shadow: 0 0 0 2px var(--accent); }
.tree-node .row .actions { display: flex; gap: 4px; opacity: 0; transition: opacity .15s; }
.tree-node .row:hover .actions { opacity: 1; }
.tree-node .row .actions button {
  width: 26px; height: 26px; border: none; background: transparent;
  cursor: pointer; border-radius: 4px; font-size: 13px; color: var(--text2);
}
.tree-node .row .actions button:hover { background: var(--accent-light); color: var(--red); }
.tree-node .children { margin-left: 20px; border-left: 2px solid var(--accent-light); padding-left: 10px; }
.preview-panel {
  flex: 2; background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 22px; overflow-y: auto;
  display: flex; flex-direction: column;
}
.preview-panel h3 { font-size: 15px; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
.preview-slide {
  background: #fff; border: 1px solid var(--border); border-radius: 8px;
  box-shadow: var(--shadow-slide);
  overflow: hidden;
  min-height: 320px;
  position: relative;
}
.preview-slide .slide-accent-bar {
  height: 5px; background: var(--accent-bar);
}
.preview-slide .slide-inner {
  padding: 28px 34px;
}
.preview-slide .slide-page-num {
  position: absolute; bottom: 12px; right: 20px;
  font-size: 11px; color: #b0b5bd; font-weight: 500;
}
.preview-slide .slide-title {
  font-size: 24px; font-weight: 700; margin-bottom: 22px;
  color: var(--text); letter-spacing: -0.3px;
  padding-bottom: 14px; border-bottom: 2px solid #f0f0f4;
}
.preview-slide .slide-body {
  font-size: 15px; line-height: 2.0; color: #4a4d55;
}
.preview-slide .slide-body ul { padding-left: 1.2em; list-style: none; }
.preview-slide .slide-body ul li { margin-bottom: 8px; position: relative; }
.preview-slide .slide-body ul li::before { content: '•'; position: absolute; left: -1em; color: var(--accent); font-weight: 700; }
.preview-slide .slide-body .placeholder { color: #b8bcc4; font-style: italic; }
.preview-slide .slide-body b { color: var(--text); }
.preview-slide .slide-body table { font-size: 13px; width: 100%; border-collapse: collapse; margin: 8px 0; }
.preview-slide .slide-body table th { background: #f5f6f8; padding: 7px 10px; text-align: left; font-weight: 600; }
.preview-slide .slide-body table td { padding: 6px 10px; border-bottom: 1px solid #f0f0f4; }

/* Stacked slides (multi-page preview) */
.preview-slides-stack {
  display: flex; flex-direction: column; gap: 20px;
}
.stacked-slide {
  background: #fff; border: 1px solid var(--border); border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,.06);
  overflow: hidden; position: relative;
  min-height: 200px; flex-shrink: 0;
}
.stacked-slide .slide-accent-bar { height: 4px; background: var(--accent-bar); }
.stacked-slide .slide-inner { padding: 22px 28px; }
.stacked-slide .slide-title {
  font-size: 20px; font-weight: 700; margin-bottom: 14px;
  color: var(--text); padding-bottom: 10px; border-bottom: 2px solid #f0f0f4;
}
.stacked-slide .slide-body { font-size: 14px; line-height: 1.9; color: #4a4d55; }
.stacked-slide .slide-body ul { padding-left: 1.2em; list-style: none; }
.stacked-slide .slide-body ul li { margin-bottom: 6px; position: relative; }
.stacked-slide .slide-body ul li::before { content: '•'; position: absolute; left: -1em; color: var(--accent); font-weight: 700; }
.stacked-slide .slide-body .placeholder { color: #b8bcc4; font-style: italic; }
.stacked-slide .slide-body b { color: var(--text); }
.stacked-slide .slide-body table { font-size: 12px; width: 100%; border-collapse: collapse; margin: 6px 0; }
.stacked-slide .slide-body table th { background: #f5f6f8; padding: 5px 8px; text-align: left; font-weight: 600; }
.stacked-slide .slide-body table td { padding: 4px 8px; border-bottom: 1px solid #f0f0f4; }
.stacked-slide .slide-page-num {
  position: absolute; bottom: 10px; right: 16px;
  font-size: 11px; color: #b0b5bd; font-weight: 500;
}
.stacked-slide code {
  font-family: 'SF Mono', Consolas, monospace; font-size: 13px;
  line-height: 1.6; white-space: pre-wrap;
}

/* Workshop panel */
.workshop-layout {
  display: flex; gap: 20px; flex: 1; overflow: hidden;
}
.workshop-cards {
  flex: 2; display: flex; flex-wrap: wrap; gap: 14px; overflow-y: auto;
  align-content: flex-start; padding: 4px;
}
.task-card {
  width: calc(50% - 7px); background: var(--surface);
  border: 2px solid var(--border); border-radius: var(--radius);
  padding: 18px; transition: all .2s;
}
.task-card.running { border-left: 4px solid var(--accent); }
.task-card.paused { border-left: 4px solid var(--amber); background: var(--amber-light); }
.task-card.done { border-left: 4px solid var(--green); opacity: .85; }
.task-card .card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.task-card .card-header .card-icon { font-size: 20px; }
.task-card .card-header .card-title { font-weight: 600; font-size: 14px; flex: 1; }
.task-card .card-header .card-status {
  font-size: 12px; padding: 4px 10px; border-radius: 14px; font-weight: 500;
}
.task-card.running .card-status { background: var(--accent-light); color: var(--accent); }
.task-card.paused .card-status { background: var(--amber-light); color: var(--amber); }
.task-card.done .card-status { background: var(--green-light); color: var(--green); }
.task-card .card-preview {
  font-size: 13px; color: var(--text2); line-height: 1.6;
  max-height: 66px; overflow: hidden; margin-bottom: 12px;
  white-space: pre-wrap;
}
.task-card .card-bar {
  height: 5px; background: #eee; border-radius: 3px; margin-bottom: 12px;
  overflow: hidden;
}
.task-card .card-bar .fill {
  height: 100%; border-radius: 3px; transition: width .3s;
  background: var(--accent);
}
.task-card.paused .card-bar .fill { background: var(--amber); }
.task-card.done .card-bar .fill { background: var(--green); }
.task-card .card-actions { display: flex; gap: 8px; }
.task-card .card-actions button {
  padding: 6px 14px; border: 1px solid var(--border); border-radius: 18px;
  background: #fff; font-size: 12px; cursor: pointer; transition: all .15s;
  font-family: var(--font);
}
.task-card .card-actions button:hover { background: var(--accent-light); }
.task-card .card-actions button.pause-btn { color: var(--amber); border-color: #fcd34d; }
.task-card .card-actions button.resume-btn { color: var(--accent); border-color: var(--blue); }
.task-card .card-actions button.edit-btn { color: var(--accent2); border-color: var(--blue); }

/* Edit instruction modal */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,.35); z-index: 100;
  align-items: center; justify-content: center;
}
.modal-overlay.show { display: flex; }
.modal-box {
  background: var(--surface); border-radius: var(--radius);
  padding: 28px; width: 500px;
}
.modal-box h4 { margin-bottom: 14px; font-size: 16px; }
.modal-box textarea {
  width: 100%; height: 110px; border: 2px solid var(--border);
  border-radius: var(--radius-sm); padding: 12px; font-size: 14px;
  font-family: var(--font); resize: vertical;
}
.modal-box textarea:focus { outline: none; border-color: var(--accent); }
.modal-box .btns { display: flex; gap: 10px; justify-content: flex-end; margin-top: 14px; }
.modal-box .btns button {
  padding: 10px 22px; border-radius: 8px; border: none;
  cursor: pointer; font-size: 14px; font-weight: 500; font-family: var(--font);
}
.modal-box .btns .cancel { background: #eee; color: var(--text); }
.modal-box .btns .confirm { background: var(--accent); color: #fff; }
.modal-box .btns .confirm:hover { background: var(--accent2); }

/* Review panel */
.review-layout { display: flex; gap: 20px; flex: 1; overflow: hidden; }
.review-list { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; }
.review-item {
  padding: 18px; border-radius: var(--radius-sm); border: 2px solid var(--border);
  background: var(--surface); cursor: pointer; transition: all .15s;
  display: flex; align-items: flex-start; gap: 14px;
}
.review-item:hover { border-color: var(--accent); }
.review-item .sev {
  padding: 5px 10px; border-radius: 14px; font-size: 12px; font-weight: 600;
  white-space: nowrap;
}
.review-item .sev.warn { background: var(--amber-light); color: #d97706; }
.review-item .sev.info { background: var(--accent-light); color: var(--accent2); }
.review-item .sev.err { background: var(--red-light); color: #dc2626; }
.review-item .body { flex: 1; font-size: 14px; line-height: 1.7; }
.review-item .body strong { display: block; margin-bottom: 4px; }
.review-detail {
  flex: 1.5; background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 22px; overflow-y: auto;
}

/* Export panel */
.export-content {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 24px; text-align: center;
}
.export-card {
  background: var(--surface); border: 2px solid var(--accent-light);
  border-radius: var(--radius); padding: 40px 56px;
}
.export-card .check-icon { font-size: 64px; margin-bottom: 16px; }
.export-card h2 { font-size: 22px; margin-bottom: 10px; }
.export-card p { font-size: 14px; color: var(--text2); margin-bottom: 24px; }
.export-btns { display: flex; gap: 14px; }
.export-btns button {
  padding: 12px 28px; border-radius: 10px; border: none;
  cursor: pointer; font-size: 15px; font-weight: 600; font-family: var(--font);
  transition: all .15s;
}
.export-btns .btn-pptx { background: var(--accent); color: #fff; }
.export-btns .btn-pptx:hover { background: var(--accent2); }
.export-btns .btn-pdf { background: #1e1e1e; color: #fff; }
.export-btns .btn-pdf:hover { background: #333; }
.export-btns .btn-history { background: #fff; color: var(--text); border: 2px solid var(--border); }
.export-btns .btn-history:hover { background: var(--accent-light); }

/* ===== Bottom action bar ===== */
.action-bar {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 24px; background: var(--surface);
  border-top: 2px solid var(--accent-light); z-index: 10;
}
.action-bar .hint { font-size: 13px; color: var(--text2); flex: 1; }
.action-bar button {
  padding: 11px 26px; border-radius: 10px; border: none;
  cursor: pointer; font-size: 15px; font-weight: 600; font-family: var(--font);
  transition: all .15s;
}
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover { background: var(--accent2); }
.btn-primary:disabled { background: #ccc; cursor: not-allowed; }
.btn-secondary { background: #fff; color: var(--text); border: 2px solid var(--border); }
.btn-secondary:hover { background: var(--accent-light); }

/* ===== Toast ===== */
.toast {
  position: fixed; top: 20px; right: 20px; z-index: 200;
  padding: 14px 22px; background: #2d2640; color: #fff;
  border-radius: 10px; font-size: 14px; font-weight: 500;
  pointer-events: none; opacity: 0; transform: translateY(-10px);
  transition: all .3s;
}
.toast.show { opacity: 1; transform: translateY(0); }

/* ===== Animations ===== */
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }
.pulse { animation: pulse 1.5s infinite; }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
.fade-in { animation: fadeInUp .4s ease; }
@keyframes spin { to { transform: rotate(360deg); } }

/* Responsive */
@media (max-width: 768px) {
  .focus-grid { grid-template-columns: 1fr; }
  .blueprint-layout { flex-direction: column; }
  .tree-panel { max-width: none; }
  .workshop-layout { flex-direction: column; }
  .task-card { width: 100%; }
  .review-layout { flex-direction: column; }
}
</style>
</head>
<body>

<!-- Top Bar -->
<div class="topbar">
  <span class="logo">◈ StructuSlide</span>
  <span style="font-size:14px;color:var(--text2);">AI Native PPT 编辑器</span>
  <span class="sep"></span>
  <span class="badge">🧪 Demo 原型</span>
</div>

<!-- Steps -->
<div class="steps" id="stepsBar">
  <div class="step active" data-step="0"><span class="num">1</span>上传论文</div>
  <div class="step" data-step="1"><span class="num">2</span>选择侧重点</div>
  <div class="step" data-step="2"><span class="num">3</span>叙事蓝图</div>
  <div class="step" data-step="3"><span class="num">4</span>并行生成</div>
  <div class="step" data-step="4"><span class="num">5</span>总览检查</div>
  <div class="step" data-step="5"><span class="num">6</span>导出</div>
</div>

<!-- Main Content -->
<div class="main" id="mainContent"></div>

<!-- Action Bar -->
<div class="action-bar" id="actionBar">
  <span class="hint" id="actionHint">拖拽 PDF 文件到上方区域，或点击上传</span>
  <button class="btn-secondary" id="btnReset" onclick="resetAll()" style="display:none;">↺ 重新开始</button>
  <button class="btn-primary" id="btnNext" disabled onclick="nextStep()">下一步 →</button>
</div>

<!-- Edit Instruction Modal -->
<div class="modal-overlay" id="editModal">
  <div class="modal-box">
    <h4>✏️ 修改生成指令</h4>
    <textarea id="editInstruction" placeholder="输入新的生成指令..."></textarea>
    <div class="btns">
      <button class="cancel" onclick="closeEditModal()">取消</button>
      <button class="confirm" onclick="confirmEditInstruction()">保存并恢复生成</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ==================== State ====================
const STATE = {
  step: 0,
  uploadedFile: null,
  selectedFocus: null,
  blueprint: null,
  tasks: [],
  reviewItems: [],
  editingTaskId: null,
};

// ==================== Data ====================
const FOCUS_MODES = [
  { id: 'overview', icon: '📋', title: '综述概览', desc: '全面覆盖论文各部分，适合文献汇报。均衡分配背景、方法、结果、讨论的篇幅。' },
  { id: 'method', icon: '🔬', title: '方法深挖', desc: '重点突出方法论与算法细节。适合需要讲解技术方案或复现实验的场景。' },
  { id: 'experiment', icon: '🧪', title: '实验复现', desc: '聚焦实验设计、数据集、评估指标。适合讨论实验有效性或对比分析的场景。' },
  { id: 'critical', icon: '💬', title: '批判性讨论', desc: '以论文优缺点分析为主线。适合组会讨论或审稿类汇报，强化批判性思考。' },
];

const INITIAL_BLUEPRINT = [
  { id: 'bg', label: '研究背景与动机', children: [
    { id: 'bg-1', label: '问题定义与范围', children: [] },
    { id: 'bg-2', label: '现有方法的局限性', children: [] },
  ]},
  { id: 'method', label: '核心方法', children: [
