function renderTree(nodes, depth = 0) {
  return nodes.map(n => `
    <div class="tree-node" data-node-id="${n.id}">
      <div class="row" draggable="true" data-node-id="${n.id}">
        ${n.children && n.children.length > 0
          ? `<span class="toggle" onclick="toggleTreeNode('${n.id}')">▼</span>`
          : `<span style="width:18px;"></span>`}
        <span class="label"><input value="${escapeHtml(n.label)}" data-node-id="${n.id}" onchange="renameNode('${n.id}', this.value)" ondblclick="this.select()"></span>
        <span class="actions">
          <button title="添加子节点" onclick="addChildNode('${n.id}')">＋</button>
          <button title="删除" onclick="deleteNode('${n.id}')">✕</button>
        </span>
      </div>
      ${n.children && n.children.length > 0 ? `<div class="children" id="children-${n.id}">${renderTree(n.children, depth + 1)}</div>` : ''}
    </div>
  `).join('');
}

