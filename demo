function renderTaskCard(t) {
  const progress = t.status === 'done' ? 100 : (t.status === 'paused' ? t.progress : Math.min(t.progress, 95));
  const previewText = t.preview || '正在生成中...';
  return `
    <div class="task-card ${t.status} fade-in" id="card-${t.id}">
      <div class="card-header">
        <span class="card-icon">${t.icon}</span>
        <span class="card-title">${t.title}</span>
        <span class="card-status">${t.status === 'running' ? '生成中' : t.status === 'paused' ? '已暂停' : '已完成'}</span>
      </div>
      <div class="card-preview">${previewText}</div>
      <div class="card-bar"><div class="fill" style="width:${progress}%"></div></div>
      ${t.status !== 'done' ? `
        <div class="card-actions">
          ${t.status === 'running'
            ? `<button class="pause-btn" onclick="pauseTask('${t.id}')">⏸ 暂停</button>`
            : `<button class="resume-btn" onclick="resumeTask('${t.id}')">▶ 恢复</button>`}
          <button class="edit-btn" onclick="editTaskInstruction('${t.id}')">✏️ 修改指令</button>
        </div>` : `<div style="font-size:12px;color:var(--green);">✓ 生成完成 · 可点击查看</div>`}
    </div>`;
}

