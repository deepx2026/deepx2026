// ==================== Tree Operations ====================
function toggleTreeNode(id) {
  const children = document.getElementById('children-' + id);
  if (children) {
    children.style.display = children.style.display === 'none' ? '' : 'none';
    const toggle = document.querySelector(`[data-node-id="${id}"] .toggle`);
    if (toggle) toggle.textContent = children.style.display === 'none' ? '▶' : '▼';
  }
}

function renameNode(id, newLabel) {
  const bp = STATE.blueprint;
  function walk(nodes) {
    for (const n of nodes) {
      if (n.id === id) { n.label = newLabel; return true; }
      if (n.children && walk(n.children)) return true;
    }
    return false;
  }
  walk(bp);
  // Sync task title
  const task = STATE.tasks.find(t => t.id === id);
  if (task) task.title = newLabel;
}

function addChildNode(parentId) {
  const bp = STATE.blueprint;
  function walk(nodes) {
    for (const n of nodes) {
      if (n.id === parentId) {
        if (!n.children) n.children = [];
        const newId = parentId + '-c' + (n.children.length + 1);
        n.children.push({ id: newId, label: '新节点', children: [] });
        return true;
      }
      if (n.children && walk(n.children)) return true;
    }
    return false;
  }
  walk(bp);
  renderPanel();
  showToast('➕ 已添加子节点');
}

function deleteNode(id) {
  if (!confirm('确定删除该节点及其所有子节点？')) return;
  const bp = STATE.blueprint;
  function walk(nodes) {
    const idx = nodes.findIndex(n => n.id === id);
    if (idx >= 0) { nodes.splice(idx, 1); return true; }
    for (const n of nodes) { if (n.children && walk(n.children)) return true; }
    return false;
  }
  walk(bp);
  renderPanel();
  showToast('🗑 节点已删除 · 蓝图已更新');
}

// ==================== Task Operations ====================
function pauseTask(id) {
  const task = STATE.tasks.find(t => t.id === id);
  if (task) task.status = 'paused';
  updateWorkshopCards();
  showToast(`⏸ "${task.title}" 已暂停，其他任务继续运行`);
}

function resumeTask(id) {
  const task = STATE.tasks.find(t => t.id === id);
  if (task) {
    task.status = 'running';
    updateWorkshopCards();
    showToast(`▶ "${task.title}" 已恢复，按新指令重新生成`);
    // Simulate progress
    simulateProgress(id);
  }
}

function editTaskInstruction(id) {
  STATE.editingTaskId = id;
  const task = STATE.tasks.find(t => t.id === id);
  document.getElementById('editInstruction').value = task?.instruction || '';
  document.getElementById('editModal').classList.add('show');
}

function closeEditModal() {
  document.getElementById('editModal').classList.remove('show');
  STATE.editingTaskId = null;
}

function confirmEditInstruction() {
  const id = STATE.editingTaskId;
  const newInst = document.getElementById('editInstruction').value;
  if (id && newInst) {
    const task = STATE.tasks.find(t => t.id === id);
    if (task) {
      task.instruction = newInst;
      task.progress = 0;
      task.preview = '';
      task.status = 'running';
      updateWorkshopCards();
      showToast(`✏️ "${task.title}" 指令已更新，重新生成中...`);
      simulateProgress(id);
    }
  }
  closeEditModal();
}

function simulateProgress(id) {
  const task = STATE.tasks.find(t => t.id === id);
  if (!task || task.status !== 'running') return;

  const interval = setInterval(() => {
    if (task.status !== 'running') { clearInterval(interval); return; }
    task.progress += Math.random() * 6 + 3;
    if (task.progress >= 100) {
      task.progress = 100;
      task.status = 'done';
      task.preview = generatePreview(task.id);
      clearInterval(interval);
      refreshTaskCard(id);
      checkAllTasksDone();
    } else {
      task.preview = generatePartialPreview(task.id, task.progress);
      refreshTaskCard(id);
    }
  }, 1200);
}

