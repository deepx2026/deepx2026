// 默认内容（上传论文后初始状态使用）
const DEFAULT_SLIDE_CONTENTS = SLIDE_CONTENTS['overview'];

// 根据当前选中的 focus mode 获取对应内容，未选择时 fallback 到 overview
function getFocusContents() {
  const mode = STATE.selectedFocus || 'overview';
  return SLIDE_CONTENTS[mode] || SLIDE_CONTENTS['overview'];
}

// 获取某个章节在当前 focus mode 下的所有页面
function getSectionPages(sectionId) {
  const mode = STATE.selectedFocus || 'overview';
  const modePages = SECTION_PAGES[mode] || SECTION_PAGES['overview'];
  return modePages[sectionId] || SECTION_PAGES['overview'][sectionId] || [];
}

// 渲染可滚动的多页幻灯片堆叠
function renderSlideStack(sectionId) {
  const pages = getSectionPages(sectionId);
  if (!pages.length) return '<span class="placeholder">该章节暂无预览页面</span>';
  const pageMap = { 'bg': 3, 'method': 5, 'exp': 8, 'result': 11, 'conc': 14 };
  const baseNum = pageMap[sectionId] || 1;
  return pages.map((p, i) => `
    <div class="stacked-slide">
      <div class="slide-accent-bar"></div>
      <div class="slide-inner">
        <div class="slide-title">${p.title}</div>
        <div class="slide-body">${p.body}</div>
      </div>
      <div class="slide-page-num">第 ${baseNum + i} / 15 页</div>
    </div>
  `).join('');
}

// ==================== Render ====================
function renderPanel() {
  const main = document.getElementById('mainContent');
  const s = STATE.step;

  if (s === 0) main.innerHTML = renderUpload();
  else if (s === 1) main.innerHTML = renderFocus();
  else if (s === 2) main.innerHTML = renderBlueprint();
  else if (s === 3) main.innerHTML = renderWorkshop();
  else if (s === 4) main.innerHTML = renderReview();
  else if (s === 5) main.innerHTML = renderExport();

  updateSteps();
  updateActionBar();
  bindPanelEvents();
}

