function generatePartialPreview(id, progress) {
  const full = generatePreview(id);
  const chars = Math.floor(full.length * progress / 100);
  return full.substring(0, chars) + '...';
}

function updateWorkshopCards() {
  const container = document.getElementById('workshopCards');
  if (container) {
    container.innerHTML = STATE.tasks.map(t => renderTaskCard(t)).join('');
  }
}

// 仅更新单张卡片的进度条和预览文本，不重建DOM，消除闪烁
function refreshTaskCard(id) {
  const task = STATE.tasks.find(t => t.id === id);
  if (!task) return;
  const card = document.getElementById('card-' + id);
  if (!card) return;

  // 更新进度条宽度
  const bar = card.querySelector('.card-bar .fill');
  if (bar) {
    const progress = task.status === 'done' ? 100 : Math.min(task.progress, 95);
    bar.style.width = progress + '%';
  }

  // 更新预览文本
  const previewEl = card.querySelector('.card-preview');
  if (previewEl) {
    previewEl.textContent = task.preview || '正在生成中...';
  }

  // 如果任务完成，更新状态标签和边框样式
  if (task.status === 'done') {
    card.classList.remove('running');
    card.classList.add('done');
    const statusEl = card.querySelector('.card-status');
    if (statusEl) {
      statusEl.textContent = '已完成';
      statusEl.style.background = 'var(--green-light)';
      statusEl.style.color = 'var(--green)';
    }
    // 替换操作按钮为完成标记
    const actionsEl = card.querySelector('.card-actions');
    if (actionsEl) {
      actionsEl.outerHTML = '<div style="font-size:12px;color:var(--green);">✓ 生成完成 · 可点击查看</div>';
    }
  }
}

function checkAllTasksDone() {
  if (STATE.tasks.every(t => t.status === 'done')) {
    showToast('✅ 全部章节生成完成！可以进入总览检查');
  }
}

